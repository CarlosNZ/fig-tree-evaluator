{
  // Base config: the v3 library source, as the rollup build and the IDE see
  // it. `yarn compile` runs it directly; tsconfig.test.json / tsconfig.v2.json
  // extend it for the jest suites (overriding module/resolution for jest's
  // CommonJS world); the ts-node block below covers codegen/ and the
  // playground. Targets per docs-dev/v3-specs/v3-packaging.md: ES2022,
  // Node >= 20.
  "compilerOptions": {
    /* Language and environment */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // lib defaults to the ES2022 set; @types/node supplies AbortSignal etc.
    "types": ["node"],

    /* Emit — consumed by the rollup pipeline (dts bundling reads build/dts) */
    "declaration": true,
    "declarationDir": "build/dts",
    "outDir": "build",
    "rootDir": "src",
    "removeComments": true,

    /* Checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Interop */
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  // ts-node runs CommonJS (codegen scripts, yarn dev playground)
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "Node10",
      "noUnusedLocals": false,
      "noUnusedParameters": false
    }
  },
  // v3 library source only. /v2-src (the frozen v2 engine) and test/ are excluded
  // from this build config; the test runners use tsconfig.test.json / tsconfig.v2.json.
  "include": ["src"],
  "exclude": ["node_modules", "build", "v2-src", "test"]
}
