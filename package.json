{
  "name": "fig-tree-evaluator",
  "version": "3.0.0-dev",
  "description": "Module to evaluate JSON-structured expression trees",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sqlite3",
      "unrs-resolver"
    ]
  },
  "repository": "git+https://github.com/CarlosNZ/fig-tree-evaluator.git",
  "author": "Carl Smith <5456533+CarlosNZ@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "test": "jest",
    "test:v2": "jest --config jest.v2.config.js",
    "generate": "tsx codegen/buildOperatorAliasReference.ts",
    "generateMassiveQuery": "tsx codegen/generateMassiveQuery.ts",
    "getVersion": "tsx codegen/getVersion.ts",
    "lint": "eslint .",
    "build": "pnpm getVersion && rimraf ./build && rollup -c && rimraf ./build/dts",
    "compile": "rimraf ./build && tsc",
    "dev": "cp -n src/dev/playground_example.ts src/dev/playground.ts || tsx src/dev/playground.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "dequal": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.20.0",
    "axios": "^1.18.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.0.0",
    "eslint-plugin-comment-length": "^2.3.1",
    "fig-tree-evaluator": "^2.23.0",
    "jest": "^30.4.2",
    "node-fetch": "2.7.0",
    "object-property-extractor": "^1.0.14",
    "pg": "^8.22.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-bundle-size": "^1.0.3",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-sizes": "^1.1.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "bugs": {
    "url": "https://github.com/CarlosNZ/fig-tree-evaluator/issues"
  },
  "homepage": "https://github.com/CarlosNZ/fig-tree-evaluator#readme"
}
